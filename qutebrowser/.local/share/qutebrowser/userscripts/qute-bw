#!/usr/bin/env bash
# Requires: bw (bitwarden CLI), fuzzel, jq

export BW_SESSION="${BW_SESSION:-$(bw unlock --raw 2>/dev/null)}"

SELECTION=$(bw list items 2>/dev/null | jq -r '.[].name' | fuzzel --dmenu --prompt="Bitwarden: ")

if [ -n "$SELECTION" ]; then
    PASSWORD=$(bw get item "$SELECTION" 2>/dev/null | jq -r '.login.password')
    echo "insert-text $PASSWORD" >> "$QUTE_FIFO"
fi