# Ignore common junk
.stow-local-ignore
*.bak
*.sqlite
*.lz4

# neovim
nvim/.config/nvim/lazy-lock.json
# nvim-pack-lock.json should be committed for cross-machine sync

# librewolf profile data
librewolf/.librewolf/*/
librewolf/.librewolf/Profile Groups/
librewolf/.librewolf/*.ini

# tmux plugins - loaded via tpm
tmux/.config/tmux/plugins/