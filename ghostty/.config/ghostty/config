# Ghostty Config - Rosé Pine Moon Theme

# Font
font-family = Maple Mono
font-size = 16

# Theme - Rosé Pine Moon
background = #232136
foreground = #e0def4
cursor-color = #c4a7e7
cursor-style = block

# Selection
selection-background = #3e8fb0
selection-foreground = #232136

# Window
window-padding-x = 10
window-padding-y = 10


# Mouse
copy-on-select = true
