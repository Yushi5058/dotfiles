# Enable dark mode 
set recolor "true"
set recolor-keeplightness "true" 

# Define specific colors to prevent a total black screen
# Background (Dark Grey) and Foreground (Off-white)
set recolor-darkcolor "#282828"
set recolor-lightcolor "#ebdbb2"

# Clipboard and UI settings 
set selection-clipboard clipboard
set scroll-step 50 
set render-loading "false"
